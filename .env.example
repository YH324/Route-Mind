# Server
HOST=127.0.0.1
PORT=8000
SERVER_VERSION=3.3.0
REQUEST_TIMEOUT_SECONDS=90
MAX_REQUEST_BYTES=65536
ENABLE_CORS=1
WARMUP_ON_START=0

# LLM providers for intent classification.
# The code tries MiMo, then MiniMax, then GLM, then local semantic guardrails.
MIMO_API_KEY=
MIMO_CHAT_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions
MIMO_MODEL=mimo-v2.5-pro
MIMO_AUTH_TYPE=api-key

MINIMAX_API_KEY=
MINIMAX_CHAT_URL=https://api.minimax.io/v1/chat/completions
MINIMAX_MODEL=MiniMax-M3
MINIMAX_AUTH_TYPE=bearer

GLM_API_KEY=
GLM_CHAT_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash
GLM_AUTH_TYPE=bearer
INTENT_LLM_FAILURE_COOLDOWN_SECONDS=120

# Planning defaults
CENTER_LNG=104.06476
CENTER_LAT=30.65705
RADIUS=3000
TIME_BUDGET=4
CANDIDATE_POOL_SIZE=300

# Candidate diversity quotas
QUOTA_SIGHT=50
QUOTA_LEISURE=40
QUOTA_SHOPPING=25
QUOTA_FOOD=80
QUOTA_OTHER=20

# Route type limits
LIMIT_FOOD=2
LIMIT_SIGHT=2
LIMIT_SHOPPING=1
LIMIT_LEISURE=2
CONCRETE_TYPE_LIMIT=1

# Semantic search and time adjustment
SEMANTIC_TOP_K=80
SEMANTIC_BOOST=2.5
ENABLE_LLM_CANDIDATE_REVIEW=1
LLM_REVIEW_CANDIDATE_TOP_N=12
LLM_REVIEW_BONUS=1.2
AUTO_TIME_PERCENTILE=60
AUTO_TIME_THRESHOLD=0.05

# KNN cache is read-only by default. Set to 1 only when you want to update poi_knn_cache.json.
PERSIST_KNN_CACHE=0

LOG_LEVEL=INFO
